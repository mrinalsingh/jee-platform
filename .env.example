# =====================================================================
# JEE Platform — environment variables
# Copy this file to `.env` (root) or to `backend/.env` / `frontend/.env.local`
# as appropriate. Never commit the actual `.env` files.
# =====================================================================

# ---------- Shared ----------
NODE_ENV=
# development | test | production

# ---------- Backend (NestJS) ----------
# HTTP server
PORT=
# e.g. 4000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=
# e.g. http://localhost:3000

# Database (Postgres assumed; change driver if you pick another DB)
#
# Architecture §3.2 + §11.1 separates the migration role from the runtime role
# so append-only on `attempts` + `test_session_audit` is structural (REVOKE
# UPDATE/DELETE from the runtime role).
#
# DATABASE_URL connects as `app_user_login` — used by the running NestJS app.
DATABASE_URL=
# e.g. postgresql://app_user_login:password@localhost:5432/jee_platform_dev

# MIGRATION_DATABASE_URL connects as `migration_user` — used ONLY by
# `prisma migrate deploy` from CI/CD. NEVER set on Render / Vercel app env.
MIGRATION_DATABASE_URL=
# e.g. postgresql://migration_user:password@localhost:5432/jee_platform_dev

# HMAC pepper for figure-token signing (architecture §7.3).
# 32 random bytes, hex-encoded. Generate with: openssl rand -hex 32
HMAC_PEPPER=

# Redis (sessions, queues, rate limiting)
REDIS_URL=
# e.g. redis://localhost:6379

# Auth / JWT
JWT_SECRET=
JWT_EXPIRES_IN=
# e.g. 7d

# Email (transactional — pick one provider, leave the others blank)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Object storage (for question images, PDFs, user uploads)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Observability
LOG_LEVEL=
# e.g. info | debug | warn | error
SENTRY_DSN=

# ---------- Frontend (Next.js) ----------
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser — keep secrets out.
NEXT_PUBLIC_API_BASE_URL=
# e.g. http://localhost:4000

NEXT_PUBLIC_APP_NAME=
# e.g. JEE Platform

NEXT_PUBLIC_SENTRY_DSN=

# Server-only (Next.js server components / route handlers)
NEXTAUTH_SECRET=
NEXTAUTH_URL=
# e.g. http://localhost:3000

# Base URL the Next.js server components use to fetch the NestJS API.
# Required by the test-runtime server components (/test/[sessionId]/*).
# Defaults to http://localhost:3001 when unset (dev convenience only).
BACKEND_API_BASE=
# e.g. http://localhost:4000
