// JEE Platform — data model (Stage 2 of build sequence)
//
// Binding spec: §6 of docs/PROJECT CONTEXT.md.
// Five tables: problems, students, student_fingerprint_state, tests, attempts.
// The 7 fingerprint axes live on `problems` as separate, indexed columns
// (4 strings for axes 1–4, which grow organically per "no miscellaneous tags";
//  3 enums for axes 5–7, which are closed sets per §4).
//
// Append-only enforcement on `attempts` is at the app layer in v1 (the NestJS
// service exposes only INSERT). A follow-up migration will add a Postgres RULE
// rejecting UPDATE/DELETE — belt + suspenders. Not in v1 because it would block
// local-dev seeding / reset.
//
// Taxonomy values for axes 1–4 (TOPIC/SUBTOPIC/IDEA/SUB-IDEA) are NOT enforced
// at the DB level in v1 — the importer validates against /content/taxonomy/maths.yaml
// before insert. A future migration can add lookup tables + FKs if we want strict
// DB-level enforcement.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS — closed sets (§4)
// =============================================================================

// Axis 5 — ANSWER-TYPE
enum AnswerType {
  MCQ_SC   // multiple choice, single correct
  MCQ_MC   // multiple choice, multi-correct (with partial marking)
  NUM_INT  // numerical, integer
  NUM_DEC  // numerical, decimal (with specified precision)
  MAT_COL  // match-the-column / match-the-list
}

// Axis 6 — SURFACE (cognitive-load dressing; NOT the math)
enum Surface {
  SURF_PLAIN
  SURF_SET
  SURF_FUNC
  SURF_GEOM
  SURF_PARAM
  SURF_PASS
}

// Axis 7 — TRAP (the bait)
enum Trap {
  TRAP_NONE
  TRAP_EIGEN
  TRAP_CAYLEY
  TRAP_LHOP
  TRAP_NCERT
  TRAP_EDGE
  TRAP_PARTIAL
  TRAP_LENGTH
}

// Intrinsic difficulty — fixed forever, anchored to top-10-rank-level student in last 4–5 months (§5)
enum IntrinsicDifficulty {
  T1
  T2
  T3
  T4
  T5
}

// Per-student preparation stage. NOT a problem axis (§5).
enum Round {
  R1
  R2
  R3
  R4
}

// Problem lifecycle
enum ProblemStatus {
  provisional  // no human approval and/or no empirical data yet
  calibrated   // human-approved AND has ≥30 empirical attempts
}

// =============================================================================
// PROBLEMS — the question bank
// =============================================================================

model Problem {
  // Natural PK — the full question code, e.g. "MAT.SPL.ORBSUM.CNJSP.001"
  questionCode  String   @id @map("question_code")

  // ---- Axes 1–4 (open enums; canonical values in /content/taxonomy/maths.yaml) ----
  topicCode     String   @map("topic_code")       // e.g. "MAT"
  subtopicCode  String   @map("subtopic_code")    // e.g. "SPL"
  ideaCode      String   @map("idea_code")        // e.g. "ORBSUM"
  subIdeaCode   String   @map("sub_idea_code")    // e.g. "CNJSP"
  serial        Int                               // 1, 2, 3, ... within (topic, subtopic, idea, sub_idea)

  // ---- Axes 5–7 (closed enums) ----
  answerType    AnswerType @map("answer_type")
  surface       Surface
  trap          Trap

  // ---- Difficulty ----
  authoredDifficulty         IntrinsicDifficulty @map("authored_difficulty")
  authoredTimeByRound        Json                @map("authored_time_by_round")        // { R1_seconds, R2_seconds, R3_seconds, R4_seconds }
  empiricalDifficultyByRound Json?               @map("empirical_difficulty_by_round") // { R1: success_rate, ... }; nullable until ≥30 attempts
  empiricalTimeByRound       Json?               @map("empirical_time_by_round")       // { R1: median_seconds_correct, ... }; nullable

  // ---- Content ----
  statement     String   @db.Text                 // markdown + LaTeX (KaTeX/MathJax compatible)
  answer        Json                              // MCQ: { type, correct_options: ["A","B",...] }  ·  NUM: { type, value: <number>, precision?: <int> }
  solution      String   @db.Text
  wrongPaths    Json     @map("wrong_paths")      // [{ path, landed_on_option, diagnosis }, ...]

  // ---- Lifecycle ----
  status        ProblemStatus @default(provisional)

  // ---- Provenance ----
  sourceMetadata Json    @map("source_metadata")  // { inspired_by, parallel_form, generator, human_reviewer, approved_at, ... }

  // ---- Timestamps ----
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // ---- Relations ----
  attempts      Attempt[]

  // ---- Indexes: each of the 7 axes individually + difficulty + status ----
  @@unique([topicCode, subtopicCode, ideaCode, subIdeaCode, serial])
  @@index([topicCode])
  @@index([subtopicCode])
  @@index([ideaCode])
  @@index([subIdeaCode])
  @@index([answerType])
  @@index([surface])
  @@index([trap])
  @@index([authoredDifficulty])
  @@index([status])
  @@map("problems")
}

// =============================================================================
// STUDENTS
// =============================================================================

model Student {
  id          BigInt   @id @default(autoincrement())
  email       String   @unique
  fullName    String   @map("full_name")
  targetRank  Int?     @map("target_rank")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  fingerprintStates StudentFingerprintState[]
  attempts          Attempt[]

  @@map("students")
}

// =============================================================================
// STUDENT FINGERPRINT STATE — one row per student per (topic.subtopic.idea.sub_idea)
// Round and mastery are per-student per-fingerprint, NOT a property of the problem.
// =============================================================================

model StudentFingerprintState {
  studentId    BigInt   @map("student_id")
  topicCode    String   @map("topic_code")
  subtopicCode String   @map("subtopic_code")
  ideaCode     String   @map("idea_code")
  subIdeaCode  String   @map("sub_idea_code")

  round        Round
  masteryScore Float    @map("mastery_score")    // 0.0 – 1.0

  updatedAt    DateTime @updatedAt @map("updated_at")

  student      Student  @relation(fields: [studentId], references: [id])

  @@id([studentId, topicCode, subtopicCode, ideaCode, subIdeaCode])
  @@index([studentId])
  @@map("student_fingerprint_state")
}

// =============================================================================
// TESTS — store question CODES, never copies of problems (§12 rule 4)
// =============================================================================

model Test {
  id              BigInt   @id @default(autoincrement())
  title           String
  questionCodes   Json     @map("question_codes")    // ordered array of question_code strings
  durationSeconds Int      @map("duration_seconds")
  markingScheme   Json     @map("marking_scheme")    // { correct_marks, wrong_marks, partial_rules, ... }

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  attempts        Attempt[]

  @@map("tests")
}

// =============================================================================
// ATTEMPTS — APPEND-ONLY. The ground truth (§12 rule 3).
// Indexes sized for tens of millions of rows (§6).
// =============================================================================

model Attempt {
  id              BigInt   @id @default(autoincrement())
  studentId       BigInt   @map("student_id")
  questionCode    String   @map("question_code")
  testId          BigInt?  @map("test_id")            // null = standalone practice attempt

  correct         Boolean
  timeSeconds     Int      @map("time_seconds")
  visitCount      Int      @default(1) @map("visit_count")
  markedForReview Boolean  @default(false) @map("marked_for_review")
  attemptOrder    Int      @map("attempt_order")      // 1st, 2nd, 3rd attempt at this question by this student
  roundAtTime     Round    @map("round_at_time")
  hintsUsed       Int      @default(0) @map("hints_used")

  createdAt       DateTime @default(now()) @map("created_at")

  student         Student  @relation(fields: [studentId], references: [id])
  problem         Problem  @relation(fields: [questionCode], references: [questionCode])
  test            Test?    @relation(fields: [testId], references: [id])

  @@index([studentId])
  @@index([questionCode])
  @@index([createdAt])
  @@index([questionCode, createdAt])    // composite for nightly empirical-rating batch
  @@map("attempts")
}
