# =============================================================================
# Backend (NestJS) — environment variables. Copy to backend/.env and fill in.
# NEVER commit the actual .env file. The repo-root .env.example covers the
# umbrella shared variables; this file is the backend-specific delta.
# =============================================================================

# ---------------------------------------------------------------------------
# DUAL-ROLE DATABASE WIRING (Architecture §3.2 + §11.1 + Req Q / Blocker 3)
# ---------------------------------------------------------------------------
# The migration-time connection is SEPARATE from the runtime connection so
# that the running NestJS app physically cannot UPDATE / DELETE rows in the
# append-only tables (attempts, test_session_audit). Append-only enforcement
# is STRUCTURAL, not policy: app_user is not the table owner, and the REVOKE
# in migration 0012 cannot be silently bypassed by anyone holding only
# DATABASE_URL.
#
# Holders:
#   * MIGRATION_DATABASE_URL  →  GitHub Actions secrets (CI/CD only)
#                                + operator's local .env (dev only).
#                                NEVER set on Render. NEVER set on Vercel.
#   * DATABASE_URL            →  Render env var (backend runtime).
#                                Local .env in dev. This is the only one the
#                                running NestJS app ever sees.

# Used ONLY by `prisma migrate dev` and `prisma migrate deploy`.
# Connects as migration_user (member of migration_role). Owner of all tables.
MIGRATION_DATABASE_URL=postgresql://migration_user:CHANGEME@localhost:5432/jee_platform_dev

# Used by the running NestJS app at runtime. Connects as app_user_login
# (member of app_user). Cannot UPDATE/DELETE attempts or test_session_audit.
DATABASE_URL=postgresql://app_user_login:CHANGEME@localhost:5432/jee_platform_dev

# ---------------------------------------------------------------------------
# HTTP + auth
# ---------------------------------------------------------------------------
PORT=4000
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# HMAC pepper for figure-token signing (architecture §7.3).
# 32 random bytes, hex-encoded. Generate with:  openssl rand -hex 32
# Held in Render env var (prod) + Vercel env var (frontend doesn't use it,
# but kept symmetric).
# ---------------------------------------------------------------------------
HMAC_PEPPER=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info
